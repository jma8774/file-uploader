# Node environment: "development" or "production".
NODE_ENV=development

# HTTP port for the Node process. Nginx proxies /api/* and /d/* here in prod.
PORT=3000

# Public origin the frontend constructs absolute URLs from. Override in prod.
PUBLIC_BASE_URL=http://localhost:3000

# Path to the SQLite database file. Relative paths are resolved from the backend cwd.
# Dev (macOS): ./var/app.db
# Prod (Linux): /var/lib/filedrop/app.db
DATABASE_PATH=./var/app.db

# Directory uploaded files are stored under.
# Dev (macOS): ./var/uploads
# Prod (Linux): /var/lib/filedrop/uploads
UPLOAD_DIR=./var/uploads

# Hard size cap on a single upload (bytes). Default = 100 MiB.
MAX_UPLOAD_BYTES=104857600

# Hours after upload that a file expires + is deleted by the cleanup job.
FILE_TTL_HOURS=24

# Maximum total bytes of active files we keep on disk. Default = 6 GiB.
STORAGE_LIMIT_BYTES=6442450944

# Per-file outbound transfer cap. Default = 2 GiB.
PER_FILE_TRANSFER_LIMIT_BYTES=2147483648

# Global monthly outbound transfer safety cap. Default = 250 GiB.
MONTHLY_TRANSFER_SAFETY_LIMIT_BYTES=268435456000

# HMAC key used to hash request IPs before storing them on download_events.
# Required in production. Replace this placeholder with 32+ random bytes
# (e.g., `openssl rand -hex 32`).
IP_HASH_SECRET=replace-with-32-random-bytes
