# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
dist-ssr/
*.local
.vite/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets — never commit these
.env
.env.*
!.env.example
*.pem
*.key

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# Local data + Playwright temp DB (would only exist on the production Droplet, but guard anyway)
/var/
backend/var/
frontend/var/
uploads/
*.db
*.sqlite
*.sqlite3

# Test / coverage
coverage/
.nyc_output/
playwright-report/
test-results/
playwright/.cache/

# Local-only docs (deploy walkthrough, droplet runbook, etc.) — the entire
# docs/ directory is gitignored on purpose because the files in it carry
# operator details (real IP, hostname, history of mistakes) that don't
# belong in a public repo. Add docs with `git add -f` if you ever want to
# track a sanitized one.
docs/

# Misc
*.tsbuildinfo
.cache/
